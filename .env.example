# ─── DashR Environment Configuration ──────────────────────────────
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Server ──────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ────────────────────────────────────────────────────────
# SQLite file path (relative to project root)
DB_PATH=./data/dashboard.db

# ── OpenClaw Gateway ────────────────────────────────────────────────
# Your running OpenClaw gateway WebSocket URL
OPENCLAW_GATEWAY_URL=wss://localhost:18789

# Gateway auth token — run: openclaw gateway status
OPENCLAW_GATEWAY_TOKEN=

# Hook token — from your ~/.openclaw/openclaw.json hooks.token
OPENCLAW_HOOKS_TOKEN=

# Path to OpenClaw CLI binary (leave as 'openclaw' if it's in PATH)
OPENCLAW_CLI_PATH=openclaw

# ── Dashboard Security ───────────────────────────────────────────────
# Secret key for API access — change this before deploying
DASHBOARD_API_KEY=ocl-dashboard-dev-change-me
